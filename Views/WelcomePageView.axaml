<UserControl
    x:Class="Reckoner.Views.WelcomePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Reckoner.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:WelcomePageViewModel"
    mc:Ignorable="d">
    <Border Classes="page-card">
        <Grid RowDefinitions="Auto,*">

            <!--  Big logo at the top of the page  -->
            <Image
                Grid.Row="0"
                Width="500"
                Margin="0,40,0,20"
                HorizontalAlignment="Center"
                Source="avares://AvReckoner/Assets/foundationwealthp.png"
                Stretch="Uniform" />

            <!--  Buttons area under the logo  -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">

                <Button
                    Width="250"
                    Classes="primary"
                    Command="{Binding NavigateToClientsCommand}"
                    Content="🧑‍💼  Clients" />

                <Button
                    Width="250"
                    Classes="primary"
                    Command="{Binding NavigateToSimulationsCommand}"
                    Content="📈 Simulations"
                    FontSize="18" />

                <Button
                    Width="250"
                    Classes="primary"
                    Command="{Binding NavigateToSettingsCommand}"
                    Content="⚙️ Settings"
                    FontSize="18" />



            </StackPanel>
        </Grid>
    </Border>
</UserControl>
